---
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---  
   
<nav class="nav" aria-label="メインナビゲーション">
  <ul class="nav__list">
    <li><a href="/" class={`nav__link ${currentPath === '/' ? 'is-active' : ''}`}>Top</a></li>
    <li><a href="/about" class={`nav__link ${currentPath === '/about' ? 'is-active' : ''}`}>About</a></li>
    <li><a href="/works" class={`nav__link ${currentPath.startsWith('/works') ? 'is-active' : ''}`}>Works</a></li>
  </ul>
</nav>

<style>
/* ========================================
  Navigation（SP: 下固定バー / 768px〜: 索引タブ）
  ======================================== */
.nav {
  position: fixed;
  top: auto;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  transform: none;
  background-color: rgba(250, 247, 242, 0.96);
  backdrop-filter: blur(10px);
  border-top: 1px solid var(--color-line);
  padding: 6px 8px 10px;
}

.nav__list {
  display: flex;
  flex-direction: row;
  justify-content: center;
  flex-wrap: wrap;
  gap: 6px;
  list-style: none;
  margin: 0;
  padding: 0;
}

.nav__list li {
  position: relative;
}

.nav__list li::before {
  display: none;
}

.nav__link {
  position: relative;
  display: block;
  width: auto;
  min-width: unset;
  padding: 10px 14px;
  font-family: var(--font-body);
  font-size: 0.7rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  color: var(--color-text);

  text-decoration: none;
  border: 1px solid var(--color-line-2);
  border-radius: 6px;
  border-right: 1px solid var(--color-line-2);
  background: linear-gradient(165deg, #fdfaf6 0%, #efe8de 100%);
  box-shadow: 0 2px 6px rgba(58, 54, 50, 0.06);
  box-sizing: border-box;
  transition:
    color 0.2s ease,
    border-color 0.2s ease,
    box-shadow 0.2s ease,
    transform 0.2s ease;
}

.nav__list li:nth-child(2) .nav__link,
.nav__list li:nth-child(3) .nav__link,
.nav__list li:nth-child(4) .nav__link {
  background: linear-gradient(165deg, #fdfaf6 0%, #efe8de 100%);
}

.nav__link::after {
  display: none;
}

.nav__link:hover {
  color: var(--color-accent);
  border-color: rgba(200, 90, 58, 0.35);
  box-shadow: 0 4px 10px rgba(58, 54, 50, 0.08);
  transform: translateY(-2px);
}

.nav__link.is-active {
  color: var(--color-accent);
  border: 1px solid var(--color-accent);
  border-left: 1px solid var(--color-accent);
  padding-left: 14px;
  font-weight: 600;
  box-shadow: 0 2px 8px rgba(200, 90, 58, 0.1);
}

.nav__link.is-active::after {
  display: none;
}

@media (min-width: 768px) {

  .nav {
    top: 1.25rem;
    bottom: auto;
    left: auto;
    right: 0;
    background-color: transparent;
    backdrop-filter: none;
    border-top: none;
    padding: 0;
  }

  .nav__list {
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
  }

  .nav__list li::before {
    display: block;
    content: '';
    position: absolute;
    top: -4px;
    left: 50%;
    transform: translateX(-50%);
    width: 22px;
    height: 10px;
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.55);
    box-shadow: 0 1px 2px rgba(58, 54, 50, 0.12);
    z-index: 1;
    pointer-events: none;
  }

  .nav__link {
    width: 5rem;
    padding: 0.55em 14px 0.55em 20px;
    font-size: 0.72rem;
    border: 1px solid var(--color-line-2);
    border-right: none;
    border-radius: 8px 0 0 8px;
    box-shadow:
      -3px 3px 10px rgba(58, 54, 50, 0.07),
      inset 0 1px 0 rgba(255, 255, 255, 0.65);
  }

  .nav__list li:nth-child(2) .nav__link {
    background: linear-gradient(165deg, #faf6f0 0%, #ebe4d8 100%);
  }

  .nav__list li:nth-child(3) .nav__link {
    background: linear-gradient(165deg, #f8f5ee 0%, #e8e2d6 100%);
  }

  .nav__list li:nth-child(4) .nav__link {
    background: linear-gradient(165deg, #faf7f1 0%, #ece5db 100%);
  }

  .nav__link::after {
    display: block;
    content: '';
    position: absolute;
    left: 8px;
    top: 50%;
    transform: translateY(-50%);
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, #f5ebe0, #c4b8a8);
    box-shadow: inset 0 1px 2px rgba(58, 54, 50, 0.25);
  }

  .nav__link:hover {
    box-shadow:
      -4px 4px 14px rgba(58, 54, 50, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.65);
    transform: translateX(-4px);
  }

  .nav__link.is-active {
    border: 1px solid var(--color-accent);
    border-left: 3px solid var(--color-accent);
    border-right: none;
    padding-left: 17px;
    box-shadow:
      -4px 4px 14px rgba(200, 90, 58, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.5);
  }

  .nav__link.is-active::after {
    display: block;
    opacity: 0.45;
  }
  
}
</style>
