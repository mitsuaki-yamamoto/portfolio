---
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---  
   
<nav class="nav" aria-label="メインナビゲーション">
  <ul class="nav__list">
    <li><a href="/" class={`nav__link ${currentPath === '/' ? 'is-active' : ''}`}>Top</a></li>
    <li><a href="/about" class={`nav__link ${currentPath === '/about' ? 'is-active' : ''}`}>About</a></li>
    <li><a href="/works" class={`nav__link ${currentPath.startsWith('/works') ? 'is-active' : ''}`}>Works</a></li>
  </ul>
</nav>