---
import BaseLayout from '../layouts/BaseLayout.astro';
const pageTitle = "Mitsuaki Yamamoto.";
---


<BaseLayout pageTitle={pageTitle}>
  <main class="main">
    <section class="hero section">
      <div class="container">
        <p class="hero__role">— Markup Coder / Frontend Developer</p>
        <h1 class="hero__name">{pageTitle}</h1>
        <p class="hero__name-jp">山本　光明　<a href="/about" class="hero__about-link">わたしについて →</a></p>
        <div class="hero__catch">
          <p class="hero__catch-main">
            <span class="hero__catch-main__lg">想い</span><span class="hero__catch-main__sm">を</span><span class="hero__catch-main__kana"><span class="hero__catch-main__kana-dot" aria-hidden="true"></span><span class="hero__catch-main__lg">か</span></span><span class="hero__catch-main__kana"><span class="hero__catch-main__kana-dot" aria-hidden="true"></span><span class="hero__catch-main__lg">た</span></span><span class="hero__catch-main__kana"><span class="hero__catch-main__kana-dot" aria-hidden="true"></span><span class="hero__catch-main__lg">ち</span></span><span class="hero__catch-main__sm">に</span><span class="hero__catch-main__lg">！</span>
          </p>
          <p class="hero__catch-sub">あなたのイメージを、丁寧なコードで届けます。</p>
        </div>
        <div class="hero__links">
          <a href="https://twitter.com/" target="_blank" rel="noopener noreferrer">Twitter / X</a>
          <a href="https://github.com/" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="https://note.com/" target="_blank" rel="noopener noreferrer">Note</a>
        </div>

        <div class="hero__badge">
          <span class="hero__portfolio-tag">PORTFOLIO</span>
          <span class="hero__year">— 2026 —</span>
        </div>
      </div>
    </section>
    <section class="section" id="works">
      <div class="container">
        <div class="works-header">
          <h2 class="section-title">
            <span class="section-title__regular">しごと</span>
            <span class="section-title__small">の</span>
            <span class="section-title__regular">記録</span>
          </h2>
          <div class="works-categories">
            <a href="/works" class="works-category-link">WordPress</a>
            <a href="/works/astro" class="works-category-link">Astro</a>
            <a href="/works/html-css" class="works-category-link">HTML / CSS</a>
            <a href="/works/design" class="works-category-link">Design</a>
          </div>
        </div>
        <div class="works-grid">
          <div>
            <a href="/works/work-1" class="work-card work-card--rotate-left">
              <div class="work-card__tape" style="background-color: #7eb8da"></div>
              <div class="work-card__image">
                <img src="/images/common/sample.svg" alt="Corporate Website" loading="lazy" />
              </div>
              <div class="work-card__info">
                <h3 class="work-card__title">実績作品1</h3>
                <div class="work-card__tags">
                  <span class="tag tag--accent">NEW</span>
                  <span class="tag">HTML/CSS</span>
                  <span class="tag">WordPress</span>
                </div>
              </div>
            </a>
          </div>
