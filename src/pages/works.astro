---
import BaseLayout from '../layouts/BaseLayout.astro';
const pageTitle = "Mitsuaki Yamamoto.";

const allWorks = Object.values(import.meta.glob('./works/*.md', { eager: true })) as any[];
const uniqueTags = [...new Set(allWorks.flatMap((work: any) => work.frontmatter.tags))];
---

<BaseLayout pageTitle={pageTitle}> 
  <main class="main">
    <section class="section">
      <div class="container">
        <h1 class="section-title">Works <span class="sub">— 実績一覧</span></h1>
        <div class="works-filter">
            {uniqueTags.map((tag: string) => (
              <button class="filter-btn" data-filter={tag}>{tag}</button>
            ))}
        </div>

        <div class="works-grid">
           {allWorks.map((work: any) => (
            <div class="works-grid__item" data-tags={work.frontmatter.tags.join(',')}>
              <a href={work.url} class="work-card" data-tags={work.frontmatter.tags.join(',')}>
                <div class="work-card__image">
                  <img src={work.frontmatter.image.url} alt={work.frontmatter.image.alt} loading="lazy" />
                </div>
                <div class="work-card__info">
                  <h3 class="work-card__title">{work.frontmatter.title}</h3>
                  <div class="work-card__tags">
                    {work.frontmatter.tags.map((tag: string) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                </div>
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
  <script>
    const filterBtns = document.querySelectorAll('.filter-btn');
    const items = document.querySelectorAll<HTMLElement>('.works-grid__item');
    function applyFilter(filter : string) {
      filterBtns.forEach((b) => b.classList.remove('is-active'));
      const activeBtn = document.querySelector(`.filter-btn[data-filter="${filter}"]`);
      if (activeBtn) activeBtn.classList.add('is-active');
      items.forEach((item) => {
        const tags = item.getAttribute('data-tags') || '';
        item.style.display = (filter === 'all' || tags.includes(filter)) ? '' : 'none';
      });
    }

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        applyFilter(btn.getAttribute('data-filter') as string);
      });
    });

    const params = new URLSearchParams(window.location.search);
    const initialFilter = params.get('filter');
    applyFilter(initialFilter || 'all');
  </script>
</BaseLayout>

