---
import BaseLayout from "./BaseLayout.astro";
const { frontmatter } = Astro.props;
---
<BaseLayout pageTitle={frontmatter.title}>
  <section class="section">
    <div class="container">
      <a href="/works" class="back-link">← Works一覧に戻る</a>
      <article class="work-article">
        <header class="work-header">
          <h1 class="work-header__title">{frontmatter.title}</h1>
          <p class="work-header__date">作成日：{frontmatter.date}</p>
          <div class="work-header__tags">
            {frontmatter.tags.map((tag : string) => (
              <span class="tag">
                <a href={`/tags/${tag}`}>{tag}</a>
              </span>
            ))}
          </div>
        </header>
        <div class="work-thumbnail">
          <img src={frontmatter.image.url} alt={frontmatter.image.alt} />
        </div>
        <p class="work-url">サイトURL：<a href={frontmatter.siteUrl} target="_blank" rel="noopener noreferrer">{frontmatter.siteUrl}</a></p>
        <div class="work-description">
          <p>{frontmatter.description}</p>
        </div>
        <div class="work-body">
          <slot />
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
